# Обязательные
JWT_SECRET=ваш-секретный-ключ-минимум-32-символа
PORT=3000
MONGODB_URI=mongodb://localhost:27017/career_platform

# URL фронтенда (для ссылок в инвайтах: {CLIENT_URL}/register?invite=...)
# Без завершающего /. Веб-приложение использует пути /profile, /jobs, /recommendations и т.д.
CLIENT_URL=http://localhost:8081

# CORS: разрешённые origins (через запятую). Если пусто — localhost по умолчанию
# CORS_ORIGINS=http://localhost:8081,https://your-app.vercel.app

# Cookie refresh: в production по умолчанию none (нужно для SPA на другом домене, чем API).
# Переопределение: strict | lax | none
# REFRESH_TOKEN_COOKIE_SAMESITE=none

# Окружение
NODE_ENV=development

# OAuth Google (тот же Client ID, что и на фронтенде)
GOOGLE_CLIENT_ID=

# Telegram: токен бота от @BotFather (для входа через Telegram)
TELEGRAM_BOT_TOKEN=

# Rate limiting (опционально; по умолчанию 100 запросов / 15 мин на IP для всего API)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=300
# RATE_LIMIT_AUTH_MAX=5
